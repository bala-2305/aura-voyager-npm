{
  "name": "aura-voyager",
  "version": "1.0.6",
  "description": "Unified multi-provider AI SDK for Node.js — One API for OpenAI, Anthropic, Gemini, Groq, and more",
  "main": "dist/index.js",
  "module": "dist/index.es",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run type-check",
    "example": "cd examples/react-demo && npm run dev"
  },
  "keywords": [
    "ai",
    "agent",
    "react",
    "chat",
    "sdk",
    "typescript"
  ],
  "author": "Bala",
  "license": "MIT",
  "sideEffects": ["**/*.css"],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@types/react-dom": "^18.2.0 || ^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.477.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  }
}